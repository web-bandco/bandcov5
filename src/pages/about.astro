---
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Input from '@/components/ui/form/Input/Input.astro';
import Textarea from '@/components/ui/form/Textarea/Textarea.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import { Hero } from '@/components/hero';
import siteConfig from '@/config/site.config';
import CTA from '@/components/landing/CTA.astro';
import Accordion from '@/components/ui/overlay/Accordion';
import Separator from '@/components/ui/layout/Separator';
import TechStack from '@/components/landing/TechStack.astro';
import { ImageCarousel } from '@/components/ui/content/ImageCarousel';

import pennyImg from '../assets/images/cats/penny.jpg';
import poppyImg from '../assets/images/cats/poppy.jpg';
import lunaImg from '../assets/images/cats/luna.jpg';

import badmintonImg from '../assets/images/hobbies/badminton.jpg';
import computerImg from '../assets/images/hobbies/mycomputer.jpg';
import gymImg from '../assets/images/hobbies/atgym.jpg';

import hiwaveImg from '../assets/images/memoji/hi-wave.png';

const webinfo = [
  {
    title: "Brighton and Co Version 5",
    content: "Based on the Velocity template by Southwell Media. This theme teplate leverages a large number of pre-built components, which are then tailored to Brighton and Co.",
    defaultOpen: true,
  },
  {
    title: "Improvements",
    content: "A completely brand new look, with more fluid, uniform styling and animations.",
  },
  {
    title: "Performance",
    content: "Brighton and Co Version 5 uses pre-built components, built to be as lightweight and efficient as possible, whilst remaining fully accessible to every user.",
  },
  {
    title: "Visual Changes",
    content: "With Brighton and Co Version 5, the site has a completely refreshed look and feel, with more fluid animations. Moreover, a more comprehensive design system provides a more uniform and cohesive website design.",
  },
  {
    title: "More Customisation",
    content: "With the range of components available with the Velocity theme template, there are far greater options and much greater potential for future developments to Brighton and Co.",
  },
  {
    title: "More Content",
    content: "The potential for more content and features for the site is seemingly exponentially increased with the Velocity theme teplate. Blog posts in particular will benefit from this new design.",
  }
]

const catPhotos = [
  { src: pennyImg.src, alt: "Penny, a British shorthair black cat with orange eyes, laid by the window." },
  { src: poppyImg.src, alt: "Poppy, a British shorthair blue cat, with orange eyes, stood up by the window." },
  { src: lunaImg.src, alt: "Luna, a British shorthair fawn-coloured cat, with orange eyes sat like a loaf on a similar coloured carpet." },
];

const hobbyPhotos = [
  { src: badmintonImg.src, alt: "Me and my girlfriend playing badminton." },
  { src: computerImg.src, alt: "The internals of a Desktop PC I had." },
  { src: gymImg.src, alt: "A photo of some dumbbells at the gym." },
];
---

<PageLayout
  title="About"
  description="About Brighton and Co - who we are, what this site is, and more."
>
  {/* HERO SECTION WITH SPLIT LAYOUT */}
  <Hero layout="split" size="sm">
    <Badge slot="badge" pill pulse>Want to know more about B&CO?</Badge>
    <h1 slot="title">
      About <span class="text-brand-500">B&CO</span>
    </h1>
    <p slot="description">
      Learn more about Brighton and Co - who made what you're looking at right now, and more.
    </p>

    {/* THE MEMOJI CARD IN THE ASIDE SLOT */}
    <div slot="aside" class="flex flex-col items-center text-center bg-surface-primary border border-border rounded-2xl shadow-sm p-8 w-full max-w-sm mx-auto transition-all hover:shadow-md">
      <figure class="w-32 h-32 mb-6">
        <img
          src={hiwaveImg.src}
          alt="My memoji waving" 
          class="w-full h-full object-contain drop-shadow-sm hover:scale-105 transition-transform duration-300" 
        />
      </figure>
      <h2 class="text-2xl font-bold text-foreground mb-2">Hello there!</h2>
      <p class="text-foreground-muted leading-relaxed">I'm Harry, the creator of Brighton and Co.</p>
    </div>
  </Hero>
  
  {/* ACCORDION SECTION */}
  <section class="py-12 md:py-16">
      <div class="container max-w-3xl">
        {/* Centered this heading to match the flow of the Memoji card above it! */}
        <div class="text-center mb-10">
          <h2 class="text-3xl font-bold text-foreground">About the Site:</h2>
          <p class="text-foreground-muted mt-2">Some key details about this site.</p>
        </div>
        
        <Accordion 
         items={webinfo} 
         variant="card" 
         size="lg" 
         exclusive={true}
      />
    </div>
  </section>

  <section class="py-16 bg-surface-secondary border-y border-border">
    <div class="container max-w-6xl">
      
      {/* The new 2-column grid layout! */}
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-8 items-start">
        
        <div class="flex flex-col gap-6">
          <div class="text-center lg:text-left">
            <h2 class="text-3xl font-bold text-foreground">Meet the Cats</h2>
            <p class="text-foreground-muted mt-2">The real bosses behind Brighton and Co.</p>
          </div>
          <ImageCarousel images={catPhotos} client:visible />
        </div>

        <div class="flex flex-col gap-6">
          <div class="text-center lg:text-left">
            <h2 class="text-3xl font-bold text-foreground">Hobbies & Interests</h2>
            <p class="text-foreground-muted mt-2">What I'm up to when I'm not writing code.</p>
          </div>
          <ImageCarousel images={hobbyPhotos} client:visible />
        </div>

      </div>

    </div>
  </section>

  <TechStack />
  <CTA />
</PageLayout>