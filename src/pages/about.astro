---
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Input from '@/components/ui/form/Input/Input.astro';
import Textarea from '@/components/ui/form/Textarea/Textarea.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import { Hero } from '@/components/hero';
import siteConfig from '@/config/site.config';
import CTA from '@/components/landing/CTA.astro';
import Accordion from '@/components/ui/overlay/Accordion';
import Separator from '@/components/ui/layout/Separator';

const webinfo = [
  {
    title: "Brighton and Co Version 5",
    content: "Based on the Velocity template by Southwell Media. This theme teplate leverages a large number of pre-built components, which are then tailored to Brighton and Co.",
    defaultOpen: true,
  },
  {
    title: "Improvements",
    content: "A completely brand new look, with more fluid, uniform styling and animations.",
  },
  {
    title: "Performance",
    content: "Brighton and Co Version 5 uses pre-built components, built to be as lightweight and efficient as possible, whilst remaining fully accessible to every user.",
  },
  {
    title: "Visual Changes",
    content: "With Brighton and Co Version 5, the site has a completely refreshed look and feel, with more fluid animations. Moreover, a more comprehensive design system provides a more uniform and cohesive website design.",
  },
  {
    title: "More Customisation",
    content: "With the range of components available with the Velocity theme template, there are far greater options and much greater potential for future developments to Brighton and Co.",
  },
  {
    title: "More Content",
    content: "The potential for more content and features for the site is seemingly exponentially increased with the Velocity theme teplate. Blog posts in particular will benefit from this new design.",
  }
]
---

<PageLayout
  title="About"
  description="About Brighton and Co - who we are, what this site is, and more."
>
  <!-- Hero Section -->
  <Hero layout="centered" size="sm">
    <Badge slot="badge" pill pulse>Want to know more about B&CO?</Badge>

    <h1 slot="title">
      About <span class="text-brand-500">B&CO</span>
    </h1>

    <p slot="description">
      Learn more about Brighton and Co - who made what you're looking at right now, and more.
    </p>
  </Hero>
  
  <section class="py-16">
      <div class="container max-w-4xl">
        <h1 class="text-4xl font-bold text-foreground mb-8">Some key information about the site:</h1>
        <Accordion 
         items={webinfo} 
         variant="card" 
          size="lg" 
          exclusive={true}
      />
    </div>
  </section>

  <!-- Content Section -->
  <section class="py-16">
    <div class="container">
      <!-- Your content -->
    </div>
  </section>
  <Separator orientation="horizontal" class="my-20" />
  <CTA />
</PageLayout>
