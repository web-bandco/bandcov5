---

<PageLayout
  title="Terms and Conditions"
  description="Site Terms and Conditions"
>
  <Hero layout="centered" size="md">
    <h1 slot="title">
      Terms and Conditions
    </h1>
    <p slot="description">
      The terms and conditions for using the Brighton and Co website.
    </p>
  </Hero>

  <section class="py-20 bg-secondary">
    <div class="container">
      <h1 class="text-2xl font-bold text-foreground mb-6">Table of Contents:</h1>
      
      <div class="relative w-full">
        {/* FIXED: Replaced pb-4 with py-4 to make top/bottom padding symmetrical. Replaced rounded-2xl with rounded-3xl to ensure the curve is large enough to perfectly intersect both the top and bottom edges of the tabs. */}
        <nav 
          id="toc-nav"
          class="flex overflow-x-auto gap-3 py-4 rounded-3xl cursor-grab active:cursor-grabbing" 
          aria-label="Table of Contents"
        >
          {webinfo.map((item) => (
            <a 
              href={`#${item.id}`} 
              class="toc-link min-w-[160px] md:min-w-[200px] flex items-center justify-center text-center px-4 py-3 bg-background border border-border shadow-sm rounded-xl text-sm font-medium text-foreground-muted hover:text-foreground hover:border-foreground hover:bg-surface-secondary transition-all"
            >
              {item.tocLabel}
            </a>
          ))}
        </nav>
      </div>
    </div>
  </section>

  <section class="py-12 md:py-16">
      <div class="container max-w-3xl">
        <div class="text-center mb-10">
          <h2 class="text-3xl font-bold text-foreground">Brighton and Co Terms and Conditions:</h2>
          <p class="text-foreground-muted mt-2">Please read all the terms and conditions for using the site carefully.</p>
        </div>
        
        <Accordion 
         items={webinfo} 
         variant="card" 
         size="lg" 
         exclusive={true}
      />
    </div>
  </section>

  <div class="container">
    <div class="mb-10">
    <p class="text-foreground-muted mt-2">Originally published: 20/06/2026.</p>
    <p class="text-foreground-muted mt-2">Last updated: 20/06/2026.</p>
    <p class="text-foreground-muted mt-2">Terms and Conditions version: 1.0.0.</p>
    </div>
  </div>

  <Separator orientation="horizontal" class="my-20" />
  <CTA />
</PageLayout>

<style>
  html {
    scroll-behavior: smooth;
  }
  
  :global(details[id]) {
    scroll-margin-top: 6rem;
  }

  /* --- MOBILE: Hide scrollbar for a cleaner swipe experience --- */
  @media (max-width: 767px) {
    #toc-nav {
      -ms-overflow-style: none; /* IE and Edge */
      scrollbar-width: none; /* Firefox */
    }
    #toc-nav::-webkit-scrollbar {
      display: none; /* Chrome, Safari and Opera */
    }
  }

  /* --- DESKTOP: Custom elegant scrollbar --- */
  @media (min-width: 768px) {
    #toc-nav {
      /* FIXED: Changed to auto so Firefox generates a thicker, more standard scrollbar */
      scrollbar-width: auto; 
      scrollbar-color: rgba(150, 150, 150, 0.4) transparent;
    }
    
    #toc-nav::-webkit-scrollbar {
      /* FIXED: Increased from 8px to 12px for better clickability */
      height: 12px; 
    }
    
    #toc-nav::-webkit-scrollbar-track {
      background: transparent; 
      border-radius: 12px;
    }
    
    #toc-nav::-webkit-scrollbar-thumb {
      background-color: rgba(150, 150, 150, 0.4); 
      border-radius: 12px;
    }
    
    #toc-nav::-webkit-scrollbar-thumb:hover {
      background-color: rgba(150, 150, 150, 0.6); 
    }
  }
</style>

<script>
  function initTOC() {
    const slider = document.getElementById('toc-nav');
    if (!slider) return;

    // --- 1. DRAG TO SCROLL LOGIC ---
    let isDown = false;
    let startX: number;
    let scrollLeft: number;
    let isDragging = false; 

    slider.addEventListener('mousedown', (e) => {
      isDown = true;
      isDragging = false;
      startX = e.pageX - slider.offsetLeft;
      scrollLeft = slider.scrollLeft;
    });

    slider.addEventListener('mouseleave', () => { isDown = false; });
    slider.addEventListener('mouseup', () => { isDown = false; });

    slider.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      
      const x = e.pageX - slider.offsetLeft;
      // If they move the mouse more than 5 pixels, consider it a drag (not a click)
      if (Math.abs(x - startX) > 5) {
        isDragging = true;
      }
      
      const walk = (x - startX) * 2; // Scroll speed multiplier
      slider.scrollLeft = scrollLeft - walk;
    });

    // --- 2. JUMP & AUTO-OPEN LOGIC ---
    const tocLinks = document.querySelectorAll('.toc-link');
    
    tocLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        // If the user was dragging the menu, prevent the link from firing
        if (isDragging) {
          e.preventDefault();
          return;
        }

        const href = link.getAttribute('href');
        if (!href) return;
        
        const targetId = href.substring(1);
        const detailsEl = document.getElementById(targetId);

        // If we found the accordion section
        if (detailsEl && detailsEl.tagName === 'DETAILS') {
          const groupName = detailsEl.getAttribute('name');
          
          // If it's an exclusive accordion, close all others in the same group
          if (groupName) {
            const allDetails = document.querySelectorAll(`details[name="${groupName}"]`);
            allDetails.forEach(d => d.removeAttribute('open'));
          }
          
          // Open the specific section the user clicked
          detailsEl.setAttribute('open', '');
        }
      });
    });
  }

  // Initialize on first load, and re-initialize after Astro view transitions
  initTOC();
  document.addEventListener('astro:page-load', initTOC);
</script>