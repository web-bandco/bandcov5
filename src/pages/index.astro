---
import LandingLayout from '@/layouts/LandingLayout.astro';
import TextCarousel from '@/components/landing/TextCarousel.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import SiteUpdates from '@/components/landing/SiteUpdates.astro';
import CTA from '@/components/landing/CTA.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';

import { Image } from 'astro:assets';

import welcomeBg from '@/assets/images/main/home-landscape1.jpg';
import shopBg from '@/assets/images/main/home-shop.jpg';
import photoBg from '@/assets/images/main/home-photography.jpg';

import shopImg from '@/assets/images/quicklinks/shop1.jpg';
import photoImg from '@/assets/images/quicklinks/photography1.jpg';
import contactImg from '@/assets/images/quicklinks/contact1.png';
---

<LandingLayout title="Brighton and Co">
  
  <section class="relative h-screen w-full flex items-center justify-center overflow-hidden bg-black">
    
    <div id="hero-backgrounds" class="absolute inset-0 w-full h-full pointer-events-none">
      
      {/* Index 0: Welcome (EAGER LOADED, AVIF Quality 40, Capped Responsive Widths) */}
      <Image 
        src={welcomeBg} 
        alt="Landscape Welcome" 
        loading="eager"
        fetchpriority="high"
        decoding="async"
        format="avif"
        quality={40}
        widths={[640, 1024, 1366, 1920]}
        sizes="100vw"
        class="bg-layer absolute inset-0 w-full h-full object-cover scale-105 animate-slow-zoom opacity-100 transition-opacity duration-1000 ease-in-out" 
      />
      
      {/* Index 1: Shop (LAZY LOADED, Low Priority, AVIF Quality 40) */}
      <Image 
        src={shopBg} 
        alt="Shop Flatlay" 
        loading="lazy"
        fetchpriority="low"
        decoding="async"
        format="avif"
        quality={40}
        widths={[640, 1024, 1366, 1920]}
        sizes="100vw"
        class="bg-layer absolute inset-0 w-full h-full object-cover scale-105 animate-slow-zoom opacity-0 transition-opacity duration-1000 ease-in-out" 
      />
      
      {/* Index 2: Photography (LAZY LOADED, Low Priority, AVIF Quality 40) */}
      <Image 
        src={photoBg} 
        alt="Camera Shot" 
        loading="lazy"
        fetchpriority="low"
        decoding="async"
        format="avif"
        quality={40}
        widths={[640, 1024, 1366, 1920]}
        sizes="100vw"
        class="bg-layer absolute inset-0 w-full h-full object-cover scale-105 animate-slow-zoom opacity-0 transition-opacity duration-1000 ease-in-out" 
      />
      
    </div>

    {/* Dark Vignette Overlay for perfect text contrast on any photo */}
    <div class="absolute inset-0 bg-gradient-to-b from-black/80 via-black/40 to-black/90 pointer-events-none"></div>

    {/* Central Interactive Carousel */}
    <div class="relative z-10 w-full animate-in fade-in slide-in-from-bottom-8 duration-1000 mt-16 md:mt-0">
      <TextCarousel />
    </div>

    {/* Bouncing Scroll Chevron - Cleaned of any focus rings */}
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce z-20">
      <a href="#explore" class="flex items-center justify-center w-12 h-12 rounded-full bg-white/5 hover:bg-white/20 backdrop-blur-sm text-white border border-white/10 transition-colors !outline-none !ring-0 focus:!outline-none focus:!ring-0 focus-visible:!outline-none focus-visible:!ring-0" aria-label="Scroll down">
        <Icon name="chevron-down" class="w-6 h-6" />
      </a>
    </div>

  </section>

  {/* THE BENTO GRID NAVIGATION (Below the fold) */}
  <section id="explore" class="py-16 md:py-24 bg-surface-primary scroll-mt-0">
    <div class="mx-auto max-w-7xl px-6">
      <div class="mb-12 text-center md:text-left">
        <h2 class="text-3xl md:text-4xl font-bold text-foreground">Dive In</h2>
        <p class="text-foreground-muted mt-2 text-lg">Choose a department below to get started.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
        
        {/* CARD 1: SHOP (OPTIMIZED: AVIF Quality 45, precise sizes) */}
        <a href="/shop" class="group relative flex flex-col justify-end overflow-hidden rounded-3xl aspect-[4/5] md:aspect-[3/4] shadow-md hover:shadow-2xl transition-all duration-500 border border-border/50 hover:border-brand-500 !outline-none !ring-0 focus:!outline-none focus:!ring-0 focus-visible:!outline-none focus-visible:!ring-0 focus-visible:!ring-offset-0">
          <Image 
            src={shopImg} 
            alt="Shop B&Co" 
            loading="lazy"
            decoding="async"
            format="avif"
            quality={45}
            widths={[300, 400, 600, 800]}
            sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw"
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" 
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent opacity-80 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="relative z-10 p-8 flex flex-col items-start translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
            <div class="p-3 bg-white/20 text-white group-hover:bg-brand-500/20 group-hover:text-brand-400 group-hover:border-brand-500/30 backdrop-blur-md rounded-2xl mb-4 border border-white/30 transition-colors duration-300">
              <Icon name="handbag" class="w-6 h-6" />
            </div>
            <h2 class="text-3xl font-bold text-white mb-2 tracking-tight">SHOP: B&Co</h2>
            <p class="text-gray-300 text-sm md:text-base line-clamp-2">Browse the B&Co Vinted and eBay inventories — a curated variety of pre-loved items and tech.</p>
            <span class="mt-6 inline-flex items-center text-white group-hover:text-brand-400 font-bold uppercase tracking-widest text-xs transition-colors duration-300">
              Visit Shop <Icon name="arrow-right" class="ml-2 w-4 h-4 transition-transform group-hover:translate-x-1" />
            </span>
          </div>
        </a>

        {/* CARD 2: PHOTOGRAPHY (OPTIMIZED: AVIF Quality 45, precise sizes) */}
        <a href="/photography" class="group relative flex flex-col justify-end overflow-hidden rounded-3xl aspect-[4/5] md:aspect-[3/4] shadow-md hover:shadow-2xl transition-all duration-500 border border-border/50 hover:border-brand-500 !outline-none !ring-0 focus:!outline-none focus:!ring-0 focus-visible:!outline-none focus-visible:!ring-0 focus-visible:!ring-offset-0">
          <Image 
            src={photoImg} 
            alt="Photography Gallery" 
            loading="lazy"
            decoding="async"
            format="avif"
            quality={45}
            widths={[300, 400, 600, 800]}
            sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw"
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" 
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent opacity-80 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="relative z-10 p-8 flex flex-col items-start translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
            <div class="p-3 bg-white/20 text-white group-hover:bg-brand-500/20 group-hover:text-brand-400 group-hover:border-brand-500/30 backdrop-blur-md rounded-2xl mb-4 border border-white/30 transition-colors duration-300">
              <Icon name="camera" class="w-6 h-6" />
            </div>
            <h2 class="text-3xl font-bold text-white mb-2 tracking-tight">Photography</h2>
            <p class="text-gray-300 text-sm md:text-base line-clamp-2">Explore my gallery of high-resolution, original photography.</p>
            <span class="mt-6 inline-flex items-center text-white group-hover:text-brand-400 font-bold uppercase tracking-widest text-xs transition-colors duration-300">
              View Gallery <Icon name="arrow-right" class="ml-2 w-4 h-4 transition-transform group-hover:translate-x-1" />
            </span>
          </div>
        </a>

        {/* CARD 3: CONTACT (OPTIMIZED: AVIF Quality 45, precise sizes) */}
        <a href="/contact" class="group relative flex flex-col justify-end overflow-hidden rounded-3xl aspect-[4/5] md:aspect-[3/4] shadow-md hover:shadow-2xl transition-all duration-500 border border-border/50 hover:border-brand-500 !outline-none !ring-0 focus:!outline-none focus:!ring-0 focus-visible:!outline-none focus-visible:!ring-0 focus-visible:!ring-offset-0">
          <Image 
            src={contactImg} 
            alt="Contact Us" 
            loading="lazy"
            decoding="async"
            format="avif"
            quality={45}
            widths={[300, 400, 600, 800]}
            sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw"
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" 
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent opacity-80 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="relative z-10 p-8 flex flex-col items-start translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
            <div class="p-3 bg-white/20 text-white group-hover:bg-brand-500/20 group-hover:text-brand-400 group-hover:border-brand-500/30 backdrop-blur-md rounded-2xl mb-4 border border-white/30 transition-colors duration-300">
              <Icon name="mail" class="w-6 h-6" />
            </div>
            <h2 class="text-3xl font-bold text-white mb-2 tracking-tight">Get in Touch</h2>
            <p class="text-gray-300 text-sm md:text-base line-clamp-2">Have a question regarding an item, or just want to chat? Send me a message.</p>
            <span class="mt-6 inline-flex items-center text-white group-hover:text-brand-400 font-bold uppercase tracking-widest text-xs transition-colors duration-300">
              Contact Me <Icon name="arrow-right" class="ml-2 w-4 h-4 transition-transform group-hover:translate-x-1" />
            </span>
          </div>
        </a>

      </div>
    </div>
  </section>

  {/* TWO-COLUMN INFO & UPDATES SECTION */}
  <section class="py-16 md:py-24 bg-surface-secondary border-t border-border">
    <div class="mx-auto max-w-7xl px-6">
      
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch">
        
        {/* LEFT COLUMN: Behind the Brand Spotlight (FIXED: Removed md:h-[460px] so it stretches cleanly to enclose the footer) */}
        <div class="lg:col-span-5 flex flex-col justify-between h-full bg-background rounded-3xl border border-border p-8 shadow-sm">
          <div>
            <div class="flex items-center gap-3 mb-6">
              <Badge pulse pill variant="brand" class="bg-brand-500/10">Find out a bit about B&Co</Badge>
            </div>
            
            <h2 class="text-2xl md:text-3xl font-bold text-foreground tracking-tight mb-4">
              What is B&Co?
            </h2>
            
            <p class="text-foreground-muted text-sm md:text-base leading-relaxed mb-6">
              Brighton and Co (B&Co) is a personal website and hobby project, maintained by me (Harry B). It serves as the place to dive deeper into my hobby of website development, as well as a way to showcase my interests.
            </p>
            
            <ul class="space-y-3 text-sm text-foreground mb-8">
              <li class="flex items-start gap-2">
                <Icon name="check" class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" />
                <span>Completely personalised by me, Harry B.</span>
              </li>
              <li class="flex items-start gap-2">
                <Icon name="check" class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" />
                <span>Specially selected products from SHOP: B&Co Vinted and eBay.</span>
              </li>
              <li class="flex items-start gap-2">
                <Icon name="check" class="w-4 h-4 text-brand-500 shrink-0 mt-0.5" />
                <span>High-resolution, original digital photography</span>
              </li>
            </ul>
          </div>

          <div class="pt-6 border-t border-border/50 flex items-center justify-between">
            <span class="text-xs font-mono text-foreground-muted">Site Status: Almost there!</span>
            <a href="/about" class="text-xs font-bold text-brand-700 hover:underline inline-flex items-center gap-1">
              Read More <Icon name="arrow-right" class="w-3 h-3" />
            </a>
          </div>
        </div>

        {/* RIGHT COLUMN: The Site Updates Feed */}
        <div class="lg:col-span-7 w-full h-full">
          <SiteUpdates />
        </div>

      </div>

    </div>
  </section>

  <CTA />
</LandingLayout>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
  
  @keyframes slow-zoom {
    0% { transform: scale(1.05); }
    50% { transform: scale(1.1); }
    100% { transform: scale(1.05); }
  }
  .animate-slow-zoom {
    animation: slow-zoom 30s ease-in-out infinite;
  }
</style>

{/* Listener Script: Crossfades backgrounds based on Text Carousel Events */}
<script>
  document.addEventListener('slideChanged', ((e: CustomEvent) => {
    const activeIndex = e.detail.index;
    const bgLayers = document.querySelectorAll('.bg-layer');
    
    bgLayers.forEach((layer, i) => {
      if (i === activeIndex) {
        layer.classList.remove('opacity-0');
        layer.classList.add('opacity-100');
      } else {
        layer.classList.add('opacity-0');
        layer.classList.remove('opacity-100');
      }
    });
  }) as EventListener);
</script>