---
import LandingLayout from '@/layouts/LandingLayout.astro';
import { Hero } from '@/components/hero';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import SocialProof from '@/components/ui/marketing/SocialProof/SocialProof.astro';
import { TerminalDemo } from '@/components/ui/marketing/TerminalDemo';
import TechStack from '@/components/landing/TechStack.astro';
import FeatureTabs from '@/components/landing/FeatureTabs.tsx';
import LighthouseScores from '@/components/landing/LighthouseScores.astro';
import Credibility from '@/components/landing/Credibility.astro';
import CTA from '@/components/landing/CTA.astro';
import packageData from '../../package.json';
import { Card } from '@/components/ui';

// Import the React components
import { ScrollArea } from "@/components/ui/overlay/ScrollArea/scroll-area";
import Separator from '@/components/ui/layout/Separator';
import { HomeTabs } from '@/components/landing/HomeTabs';
// 1. Create a structured array for your updates
const siteUpdates = [
{
    version: "v0.5.4.0",
    date: "12 May 2026",
    title: "More Updates to the Site",
    description: "The footer layout has been updated. The full site logo - as seen in the footer has also been implemented. As well, automated version provision has been implemented."
  },
{
    version: "v0.5.3.0",
    date: "11 May 2026",
    title: "Design Changes",
    description: "The new Brighton and Co site has a new logo. This simplified logo is more versatile and works better across different contexts, especially on smaller screens."
  },  
{
    version: "v0.5.2.0",
    date: "10 May 2026",
    title: "Further Enhancements",
    description: "Made some additional improvements to the contact form to increase interacitvity. Also added this scrollable area to document changes to the site."
  },
  {
    version: "v0.5.1.4b",
    date: "9 May 2026",
    title: "More Contact Form Improvements",
    description: "Made additional improvements to the contact form, to ensure it fully works.."
  },
  {
    version: "v0.5.1.0",
    date: "9 May 2026",
    title: "Contact Form Implemented",
    description: "Fully implemented the contact form with validation and submission handling."
  },
  {
    version: "v0.5.0.1",
    date: "5th May 2026",
    title: "Theme Adjustment",
    description: "Swapped the legacy orange color palette for a perceptually uniform sky-blue theme using OKLCH."
  },
  {
    version: "v0.5.0.0",
    date: "5th May 2026",
    title: "Public Beta Launch",
    description: "Complete rewrite of Brighton and Co using Astro and the Velocity theme. Massive performance improvements."
  }
];

---

<LandingLayout
  title="Brighton and Co"
  description="Design tokens, accessible components, SEO, and i18n configured from the first commit. Velocity ships what other starters leave as homework."
>
  <Hero layout="split" size="md" showBlob blobPosition="right">
    <Badge slot="badge" pill pulse>B&Co v{packageData.version} Public Beta is Live</Badge>

    <h1 slot="title">
      Welcome to <span class="text-brand-500">Brighton and Co</span>
    </h1>

    <p slot="description">
      The brand new Brighton and Co site built with Velocity.
      This site is being actively developed and improved - if you have any feedback or suggestions, please 
      <a href="/contact" class="text-brand-500 hover:underline">get in touch</a>!
    </p>

    <Fragment slot="actions">
      <Button size="lg" <a href="/about">
        About B&Co
        <Icon name="arrow-right" size="sm" />
      </Button>
      <Button
        size="lg"
        variant="outline"
        href="https://test.brightonandco.co.uk/"
        target="_blank"
      >
        <Icon name="flask-conical" size="sm" />
        View Test Site
      </Button>
    </Fragment>

    {/* 2. Map over the structured data to build the feed UI */}
    {/* 1. Added type="auto" and removed 'p-6' from the ScrollArea wrapper */}
    <ScrollArea slot="aside" client:load type="auto" className="h-[450px] w-full max-w-[500px] rounded-xl border border-border bg-surface-secondary/50 shadow-sm backdrop-blur-sm">
      
      {/* 2. Added the p-6 padding to a div INSIDE the scroll area instead */}
      <div class="p-6">
        <div class="mb-6 flex items-center gap-2">
          <Icon name="bell" size="sm" class="text-brand-500" />
          <h2 class="text-lg font-bold text-foreground">Site Updates</h2>
        </div>
        
        <div class="flex flex-col gap-1">
          {siteUpdates.map((update, index) => (
            <>
              <div class="group flex flex-col gap-2 py-3">
                <div class="flex items-center justify-between">
                  <span class="inline-flex items-center rounded-full bg-brand-500/10 px-2.5 py-0.5 text-xs font-semibold text-brand-500 border border-brand-500/20">
                    {update.version}
                  </span>
                  <span class="text-xs font-medium text-foreground-muted/80">
                    {update.date}
                  </span>
                </div>
                <div>
                  <h3 class="text-sm font-semibold text-foreground group-hover:text-brand-500 transition-colors">
                    {update.title}
                  </h3>
                  <p class="mt-1 text-sm text-foreground-muted leading-relaxed">
                    {update.description}
                  </p>
                </div>
              </div>
              {index !== siteUpdates.length - 1 && (
                <Separator class="my-1 opacity-50" />
              )}
            </>
          ))}
        </div>
      </div>
    </ScrollArea>
    
  </Hero>
    {/* NEW PURE TAILWIND CARDS SECTION */}
  {/* 1 & 2. Added border-t, and reduced the top padding (pt-8 md:pt-12) to pull it closer to the Hero */}
  <section class="pt-8 pb-16 md:pt-10 md:pb-24 bg-surface-secondary border-t border-border">
    
    <div class="mx-auto max-w-7xl px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-8 justify-items-center">
        
        {/* Card 1: Shop */}
        <div class="flex flex-row md:flex-col items-center md:items-stretch bg-surface-primary border border-border w-full max-w-md md:max-w-sm rounded-2xl shadow-sm overflow-hidden p-3 md:p-0 transition-all">
          <a 
            href="/shop" 
            class="group shrink-0 flex items-center justify-center w-20 h-20 md:w-auto md:h-auto md:aspect-video md:mx-4 md:mt-4 md:mb-2 rounded-xl border-2 border-accent text-accent transition-all duration-300 hover:bg-accent hover:text-white"
          >
            <Icon name="handbag" class="w-8 h-8 md:w-16 md:h-16 transition-transform duration-300 group-hover:scale-110" />
          </a>
          <div class="flex flex-col flex-auto ml-4 md:ml-0 md:p-6 md:pt-2">
            <h2 class="text-lg md:text-xl font-bold text-foreground">SHOP: B&Co</h2>
            <p class="hidden md:block mt-2 text-sm md:text-base text-foreground-muted">Browse B&Co Vinted and eBay - a variety of pre-loved items.</p>
            <div class="mt-1 md:mt-4 flex items-center justify-start md:justify-end mt-auto">
              <a href="/shop" class="text-sm font-semibold text-brand-500 hover:underline">Visit Shop &rarr;</a>
            </div>
          </div>
        </div>

        {/* Card 2: Contact */}
        <div class="flex flex-row md:flex-col items-center md:items-stretch bg-surface-primary border border-border w-full max-w-md md:max-w-sm rounded-2xl shadow-sm overflow-hidden p-3 md:p-0 transition-all">
          <a 
            href="/contact" 
            class="group shrink-0 flex items-center justify-center w-20 h-20 md:w-auto md:h-auto md:aspect-video md:mx-4 md:mt-4 md:mb-2 rounded-xl border-2 border-accent text-accent transition-all duration-300 hover:bg-accent hover:text-white"
          >
            <Icon name="mail" class="w-8 h-8 md:w-16 md:h-16 transition-transform duration-300 group-hover:scale-110" />
          </a>
          <div class="flex flex-col flex-auto ml-4 md:ml-0 md:p-6 md:pt-2">
            <h2 class="text-lg md:text-xl font-bold text-foreground">Get in Touch</h2>
            <p class="hidden md:block mt-2 text-sm md:text-base text-foreground-muted">Have a question or suggestion? Send us a message.</p>
            <div class="mt-1 md:mt-4 flex items-center justify-start md:justify-end mt-auto">
              <a href="/contact" class="text-sm font-semibold text-brand-500 hover:underline">Contact Us &rarr;</a>
            </div>
          </div>
        </div>

        {/* Card 3: Photography */}
        <div class="flex flex-row md:flex-col items-center md:items-stretch bg-surface-primary border border-border w-full max-w-md md:max-w-sm rounded-2xl shadow-sm overflow-hidden p-3 md:p-0 transition-all">
          <a 
            href="/photography" 
            class="group shrink-0 flex items-center justify-center w-20 h-20 md:w-auto md:h-auto md:aspect-video md:mx-4 md:mt-4 md:mb-2 rounded-xl border-2 border-accent text-accent transition-all duration-300 hover:bg-accent hover:text-white"
          >
            <Icon name="camera" class="w-8 h-8 md:w-16 md:h-16 transition-transform duration-300 group-hover:scale-110" />
          </a>
          <div class="flex flex-col flex-auto ml-4 md:ml-0 md:p-6 md:pt-2">
            <h2 class="text-lg md:text-xl font-bold text-foreground">Photography</h2>
            <p class="hidden md:block mt-2 text-sm md:text-base text-foreground-muted">Explore a gallery of high-resolution photography.</p>
            <div class="mt-1 md:mt-4 flex items-center justify-start md:justify-end mt-auto">
              <a href="/photography" class="text-sm font-semibold text-brand-500 hover:underline">View Gallery &rarr;</a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  {/* TWO-COLUMN DASHBOARD & FEATURES SECTION */}
  {/* 1. Removed the border-t border-border from this section */}
  <section class="py-16 md:py-24 bg-surface-primary">
    <div class="mx-auto max-w-7xl px-6">
      
      {/* 3. Removed lg:gap-12 so we can handle the gap manually with padding and borders */}
      <div class="grid grid-cols-1 lg:grid-cols-10 gap-16 lg:gap-0 items-start">
        
        {/* Left Column: Added right padding (lg:pr-12) to push content away from the new divider */}
        <div class="w-full flex flex-col lg:col-span-3 lg:pr-12">
          <div class="mb-8">
            <h2 class="font-display text-foreground text-2xl font-bold md:text-3xl">
              Quick <span class="text-brand-500">Info</span>
            </h2>
            <p class="text-foreground-muted mt-3 text-base">
              Some information about B&Co.
            </p>
          </div>
          <HomeTabs client:visible />
        </div>

        {/* Right Column: Added the vertical divider (lg:border-l) and left padding (lg:pl-12) */}
        <div class="w-full flex flex-col lg:col-span-7 border-l-0 lg:border-l border-border lg:pl-12">
          <FeatureTabs client:visible />
        </div>

      </div>

    </div>
  </section>

  <TechStack />

  <CTA />
</LandingLayout>