---
/**
 * Contact page
 * URL: /contact
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Input from '@/components/ui/form/Input/Input.astro';
import Textarea from '@/components/ui/form/Textarea/Textarea.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import { Hero } from '@/components/hero';
import siteConfig from '@/config/site.config';
import CTA from '@/components/landing/CTA.astro';
import Toast from '@/components/ui/feedback/Toast/Toast.astro';
import { Separator } from '@/components/ui';
import Accordion from '@/components/ui/overlay/Accordion/Accordion.astro';
import { ExternalLink } from '@/components/ui/content/ExternalLink';

const contactFaqs = [
  {
    title: "How can I contact B&Co?",
    content: "Simply fill out the contact form on this page. Please include your name, email address, subject and your message.",
    defaultOpen: true,
  },
  {
    title: "When will I receive a response?",
    content: "The aim is to respond to all messages as soon as possible, but please allow up to 48 hours for a response, especially during busy periods.",
    defaultOpen: false,
  },
  {
    title: "What if I have a general question about B&Co?",
    content: "If you have a general question about Brighton and Co - especially about this site, you may find your answer on the About page.",    
    defaultOpen: false,
  }
];

const accessKey = "598318ee-9b49-4c95-9cc2-6b6882707fcf";
---

<PageLayout
  title="Contact"
  description="Get in touch with Brighton and Co."
>
  <Hero layout="centered" size="sm">
    <Badge slot="badge" pill pulse>Get in Touch</Badge>

    <h1 slot="title">
      Contact <span class="text-brand-500">B&Co</span>
    </h1>

    <p slot="description">
      Have a question, suggestion, or just want to say hello? We'd love to hear from you.
    </p>
  </Hero>

  <!-- Contact Section -->
  <section class="py-20 bg-surface-secondary">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-12 lg:grid-cols-2">
        <!-- Form -->
        <Card padding="lg">
          <h2 class="text-2xl font-display font-bold text-foreground mb-6">Send us a message</h2>

          <form id="contact-form" action="https://api.web3forms.com/submit" method="POST" class="space-y-6">
            
            <input type="hidden" name="access_key" value={accessKey} />
            <input type="hidden" name="subject" value="New Website Enquiry from B&Co" />
            
            <Input
              label="Your Name"
              name="name"
              type="text"
              placeholder="Joe Bloggs"
              required
              autocomplete="name"
            />

            <Input
              label="Email Address"
              name="email"
              type="email"
              placeholder="joe@bloggs.com"
              required
              autocomplete="email"
            />

            <Input
              label="Subject"
              name="User Subject"
              type="text"
              placeholder="How can we help?"
              required
            />

            <Textarea
              label="Message"
              name="message"
              placeholder="Tell us more about your question..."
              rows={5}
              required
            />

            <div class="flex justify-center w-full">
              <div class="h-captcha" data-captcha="true"></div>
            </div>

            <div id="form-message" class="hidden text-sm"></div>

            <Button type="submit" class="w-full" id="submit-button">
              <Icon name="mail" size="sm" />
              Send Message
            </Button>
          </form>
        </Card>
      <div class="flex flex-col h-full justify-between gap-12">
          <div>
            <h2 class="font-display text-2xl font-bold text-foreground mb-6">
              Quick answers
            </h2>
            <Accordion 
              items={contactFaqs} 
              variant="card" 
              size="md" 
              exclusive={true}
            />
          </div>

          <div>
            <h2 class="font-display text-2xl font-bold text-foreground mb-6">
              Other ways to reach us
            </h2>

            <div class="flex flex-col gap-4 w-full">
              
              {/* EMAIL LINK */}
              <a href={`mailto:${siteConfig.email}`} class="flex w-full outline-none focus-visible:ring-2 focus-visible:ring-brand-500 rounded-2xl">
                <div class="w-full">
                  <Card hover padding="sm">
                    <div class="flex items-center gap-4">
                      <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                        <Icon name="mail" size="md" />
                      </div>
                      <div>
                        <p class="text-sm text-foreground-muted">Email</p>
                        <p class="font-medium text-foreground">{siteConfig.email}</p>
                      </div>
                    </div>
                  </Card>
                </div>
              </a>

              {/* GITHUB LINK (Changed to client:visible) */}
              <ExternalLink
                client:visible
                href="https://github.com/web-bandco"
                showIndicator={false}
                className="!flex w-full" 
              >
                <div class="w-full">
                  <Card hover padding="sm">
                    <div class="flex items-center gap-4">
                      <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                        <Icon name="github" size="md" />
                      </div>
                      <div>
                        <p class="text-sm text-foreground-muted">GitHub</p>
                        <p class="font-medium text-foreground">web-bandco</p>
                      </div>
                    </div>
                  </Card>
                </div>
              </ExternalLink>

              {/* TWITTER LINK (Changed to client:visible) */}
              {siteConfig.twitter && (
                <ExternalLink
                  client:visible
                  href={`https://twitter.com/${siteConfig.twitter.site.replace('@', '')}`}
                  showIndicator={false}
                  className="!flex w-full"
                >
                  <div class="w-full">
                    <Card hover padding="sm">
                      <div class="flex items-center gap-4">
                        <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                          <Icon name="twitter" size="md" />
                        </div>
                        <div>
                          <p class="text-sm text-foreground-muted">Twitter</p>
                          <p class="font-medium text-foreground">{siteConfig.twitter.site}</p>
                        </div>
                      </div>
                    </Card>
                  </div>
                </ExternalLink>
              )}
              
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <Separator orientation="horizontal" className="my-20" />
  <CTA />
  <Toast />

  {/* Removed the blocking inline script. The dynamic loader below handles it instead. */}
</PageLayout>

<script>
  function initContactForm() {
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const button = document.getElementById('submit-button') as HTMLButtonElement;

    if (!form || !button) return;

    // --- DYNAMIC HCAPTCHA LOADER ---
    let captchaLoaded = false;
    const loadCaptcha = () => {
      if (captchaLoaded) return;
      captchaLoaded = true;
      const script = document.createElement('script');
      script.src = "https://web3forms.com/client/script.js";
      script.async = true;
      script.defer = true;
      document.head.appendChild(script);
    };

    // Inject the script the moment the user shows intent to interact
    form.addEventListener('mouseenter', loadCaptcha, { passive: true, once: true });
    form.addEventListener('touchstart', loadCaptcha, { passive: true, once: true });
    form.addEventListener('focusin', loadCaptcha, { passive: true, once: true });
    // --------------------------------

    const originalButtonHTML = button.innerHTML;
    
    const spinnerSVG = `<svg class="animate-spin shrink-0 h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>`;
    const checkSVG = `<svg class="shrink-0 h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
    const xSVG = `<svg class="shrink-0 h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>`;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = new FormData(form);

      const hCaptchaResponse = formData.get('h-captcha-response');
      if (!hCaptchaResponse) {
        window.dispatchEvent(
          new CustomEvent('show-toast', {
            detail: { title: 'Security Check Required', description: 'Please complete the hCaptcha before sending your message.', variant: 'error' },
          })
        );
        return;
      }

      button.disabled = true;
      button.innerHTML = `${spinnerSVG} Sending...`;
      button.classList.remove('!bg-green-600', '!bg-red-600', '!text-white', '!opacity-100');

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: formData,
          headers: {
            'Accept': 'application/json'
          }
        });

        const data = await response.json();

        if (data.success) {
          button.innerHTML = `${checkSVG} Sent!`;
          button.classList.add('!bg-green-600', '!text-white', '!opacity-100');
          form.reset();
          
          if ((window as any).hcaptcha) {
            (window as any).hcaptcha.reset();
          }

          window.dispatchEvent(
            new CustomEvent('show-toast', {
              detail: { title: 'Message Sent', description: 'We will get back to you soon.', variant: 'success' },
            })
          );
        } else {
          const errors = data.message || 'Something went wrong';
          button.innerHTML = `${xSVG} Failed`;
          button.classList.add('!bg-red-600', '!text-white', '!opacity-100');

          window.dispatchEvent(
            new CustomEvent('show-toast', {
              detail: { title: 'Failed to send', description: errors, variant: 'error' },
            })
          );
        }
      } catch {
        button.innerHTML = `${xSVG} Failed`;
        button.classList.add('!bg-red-600', '!text-white', '!opacity-100');

        window.dispatchEvent(
          new CustomEvent('show-toast', {
            detail: { title: 'Error', description: 'Failed to send message. Please try again later.', variant: 'error' },
          })
        );
      } finally {
        setTimeout(() => {
          button.innerHTML = originalButtonHTML;
          button.classList.remove('!bg-green-600', '!bg-red-600', '!text-white', '!opacity-100');
          button.disabled = false;
        }, 3000);
      }
    });
  }

  initContactForm();
  document.addEventListener('astro:after-swap', initContactForm);
</script>