---
/**
 * Contact page
 * URL: /contact
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Input from '@/components/ui/form/Input/Input.astro';
import Textarea from '@/components/ui/form/Textarea/Textarea.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import { Hero } from '@/components/hero';
import GoogleMap from '@/components/ui/data-display/GoogleMap/GoogleMap.astro';
import siteConfig from '@/config/site.config';
import CTA from '@/components/landing/CTA.astro';
import Toast from '@/components/ui/feedback/Toast/Toast.astro';
import { Separator } from '@/components/ui';
---

<PageLayout
  title="Contact Us"
  description="Get in touch with Brighton and Co."
>
  <Hero layout="centered" size="sm">
    <Badge slot="badge" pill pulse>Get in Touch</Badge>

    <h1 slot="title">
      Let's <span class="text-brand-500">connect.</span>
    </h1>

    <p slot="description">
      Have a question, suggestion, or just want to say hello? We'd love to hear from you.
    </p>
  </Hero>

  <!-- Contact Section -->
  <section class="py-20 bg-surface-secondary">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-12 lg:grid-cols-2">
        <!-- Form -->
        <Card padding="lg">
          <h2 class="text-2xl font-display font-bold text-foreground mb-6">Send us a message</h2>

          <form id="contact-form" action="/api/contact" method="POST" class="space-y-6">
            <Input
              label="Your Name"
              name="name"
              type="text"
              placeholder="Joe Bloggs"
              required
              autocomplete="name"
            />

            <Input
              label="Email Address"
              name="email"
              type="email"
              placeholder="joe@bloggs.com"
              required
              autocomplete="email"
            />

            <Input
              label="Subject"
              name="subject"
              type="text"
              placeholder="How can we help?"
              required
            />

            <Textarea
              label="Message"
              name="message"
              placeholder="Tell us more about your question..."
              rows={5}
              required
            />

            <!-- Honeypot field for spam protection -->
            <div class="hidden" aria-hidden="true">
              <input type="text" name="honeypot" tabindex="-1" autocomplete="off" />
            </div>

            <div id="form-message" class="hidden text-sm"></div>

            <Button type="submit" class="w-full" id="submit-button">
              <Icon name="mail" size="sm" />
              Send Message
            </Button>
          </form>
        </Card>

        <!-- Right column: Map + Contact Info -->
        <div class="flex flex-col gap-8">
          {/* Map */}
          <GoogleMap
            size="sm"
            ariaLabel={`Map showing ${siteConfig.name} location`}
            placeholderTitle="Our Location"
          />

          {/* Contact Info */}
          <div>
            <h2 class="font-display text-2xl font-bold text-foreground mb-6">
              Other ways to reach us
            </h2>

            <div class="space-y-4">
              <!-- Email -->
              <a href={`mailto:${siteConfig.email}`} class="block">
                <Card hover padding="sm">
                  <div class="flex items-center gap-4">
                    <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                      <Icon name="mail" size="md" />
                    </div>
                    <div>
                      <p class="text-sm text-foreground-muted">Email</p>
                      <p class="font-medium text-foreground">{siteConfig.email}</p>
                    </div>
                  </div>
                </Card>
              </a>

              <!-- GitHub -->
              <a
                href="https://github.com/ItsHarryB"
                target="_blank"
                rel="noopener noreferrer"
                class="block"
              >
                <Card hover padding="sm">
                  <div class="flex items-center gap-4">
                    <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                      <Icon name="github" size="md" />
                    </div>
                    <div>
                      <p class="text-sm text-foreground-muted">GitHub</p>
                      <p class="font-medium text-foreground">ItsHarryB</p>
                    </div>
                  </div>
                </Card>
              </a>

              <!-- Twitter -->
              {siteConfig.twitter && (
                <a
                  href={`https://twitter.com/${siteConfig.twitter.site.replace('@', '')}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="block"
                >
                  <Card hover padding="sm">
                    <div class="flex items-center gap-4">
                      <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                        <Icon name="twitter" size="md" />
                      </div>
                      <div>
                        <p class="text-sm text-foreground-muted">Twitter</p>
                        <p class="font-medium text-foreground">{siteConfig.twitter.site}</p>
                      </div>
                    </div>
                  </Card>
                </a>
              )}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <Separator orientation="horizontal" className="my-20" />
  <CTA />
  <Toast />
</PageLayout>

<script>
  function initContactForm() {
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const button = document.getElementById('submit-button') as HTMLButtonElement;

    if (!form || !button) return;

    const originalButtonHTML = button.innerHTML;
    
    const spinnerSVG = `<svg class="animate-spin shrink-0 h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>`;
    const checkSVG = `<svg class="shrink-0 h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
    const xSVG = `<svg class="shrink-0 h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>`;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      button.disabled = true;
      button.innerHTML = `${spinnerSVG} Sending...`;
      
      // ✅ Updated to remove new classes
      button.classList.remove('!bg-green-600', '!bg-red-600', '!text-white', '!opacity-100');

      try {
        const formData = new FormData(form);
        const response = await fetch('/api/contact', {
          method: 'POST',
          body: formData,
        });

        const data = await response.json();

        if (data.success) {
          button.innerHTML = `${checkSVG} Sent!`;
          // ✅ Added !opacity-100 so it doesn't look greyed out
          button.classList.add('!bg-green-600', '!text-white', '!opacity-100');
          form.reset();

          window.dispatchEvent(
            new CustomEvent('show-toast', {
              detail: { title: 'Message Sent', description: 'We will get back to you soon.', variant: 'success' },
            })
          );
        } else {
          const errors = data.errors ? Object.values(data.errors).flat().join(', ') : 'Something went wrong';
          button.innerHTML = `${xSVG} Failed`;
          // ✅ Changed to standard Tailwind red and forced opacity
          button.classList.add('!bg-red-600', '!text-white', '!opacity-100');

          window.dispatchEvent(
            new CustomEvent('show-toast', {
              detail: { title: 'Failed to send', description: errors, variant: 'error' },
            })
          );
        }
      } catch {
        button.innerHTML = `${xSVG} Failed`;
        // ✅ Changed to standard Tailwind red and forced opacity
        button.classList.add('!bg-red-600', '!text-white', '!opacity-100');

        window.dispatchEvent(
          new CustomEvent('show-toast', {
            detail: { title: 'Error', description: 'Failed to send message. Please try again later.', variant: 'error' },
          })
        );
      } finally {
        setTimeout(() => {
          button.innerHTML = originalButtonHTML;
          // ✅ Clean up all the override classes
          button.classList.remove('!bg-green-600', '!bg-red-600', '!text-white', '!opacity-100');
          button.disabled = false;
        }, 3000);
      }
    });
  }

  initContactForm();
  document.addEventListener('astro:after-swap', initContactForm);
</script>
