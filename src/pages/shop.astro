---
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Input from '@/components/ui/form/Input/Input.astro';
import Textarea from '@/components/ui/form/Textarea/Textarea.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import { Hero } from '@/components/hero';
import siteConfig from '@/config/site.config';
import CTA from '@/components/landing/CTA.astro';
---

<PageLayout
  title="Shop"
  description="Add your description here"
>
  <!-- Hero Section -->
   <Hero layout="centered" size="sm">
    <Badge slot="badge" pill pulse>Looking for something new?</Badge>

    <h1 slot="title">
      SHOP: <span class="text-brand-500">B&CO</span>
    </h1>

    <p slot="description">
      Check out a range of items below from Brighton and Co's Vinted and eBay stores.
    </p>
  </Hero>
  <section class="py-20 bg-secondary">
    <div class="container">
      <h1 class="text-4xl font-bold text-foreground">Shop</h1>
      <p class="mt-4 text-foreground-muted max-w-2xl">
        Add your content here.
      </p>
    </div>
  </section>

  <!-- Content Section -->
  <section class="py-16">
    <div class="container">
      <!-- Your content -->
    </div>
  </section>
    <CTA />
</PageLayout>
