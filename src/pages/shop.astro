---
import PageLayout from '@/layouts/PageLayout.astro';
import { Hero } from '@/components/hero';
import CTA from '@/components/landing/CTA.astro';
import shopLogo from '@/assets/branding/shoplogo.png';
import { ShopCarousel } from '@/components/ui/content/ShopCarousel';
import { SiVinted, SiEbay } from "react-icons/si";

import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

import edHardy1 from '@/assets/shop/vinted/edhardy1.jpg';
import edHardy2 from '@/assets/shop/vinted/edhardy2.jpg';
import edHardy3 from '@/assets/shop/vinted/edhardy3.jpg';

import fleece1 from '@/assets/shop/vinted/fleece1.jpg';
import fleece2 from '@/assets/shop/vinted/fleece2.jpg';
