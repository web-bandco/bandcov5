---
import '@/styles/global.css';
import SEO from '@/components/seo/SEO.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import Analytics from '@/components/layout/Analytics.astro';
import ConsentBanner from '@/components/ui/overlay/ConsentBanner';
import { ClientRouter } from 'astro:transitions';
import { createWebsiteSchema, createOrganizationSchema } from '@/lib/schema';
import type { WebSite, Organization, WithContext } from 'schema-dts';
import siteConfig from '@/config/site.config';
import Footer from '@/components/layout/Footer.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import lightLogo from '@/assets/branding/logo-full.png';
import darkLogo from '@/assets/branding/logo-full-dark.png';
import packageData from '../../package.json';

// NEW IMPORTS: The interactive link component and the global dialog
import { ExternalLink } from '@/components/ui/content/ExternalLink';
import { GlobalExternalLinkDialog } from '@/components/ui/content/GlobalExternalLinkDialog';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  article?: {
    publishedTime?: Date;
    modifiedTime?: Date;
    authors?: string[];
    tags?: string[];
  };
  noindex?: boolean;
  nofollow?: boolean;
  includeOrgSchema?: boolean;
}

const {
  title,
  description,
  image,
  imageAlt,
  article,
  noindex = false,
  nofollow = false,
  includeOrgSchema = false,
} = Astro.props;

// Build JSON-LD schemas
const schemas: Array<WithContext<WebSite> | WithContext<Organization>> = [createWebsiteSchema()];
if (includeOrgSchema) {
  schemas.push(createOrganizationSchema());
}
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={siteConfig.branding.favicon.svg} />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content={siteConfig.branding.colors.themeColor} />

    <!-- SEO -->
    <SEO
      title={title}
      description={description}
      image={image}
      imageAlt={imageAlt}
      article={article}
      noindex={noindex}
      nofollow={nofollow}
    />

    <!-- RSS Feed -->
    <link rel="alternate" type="application/rss+xml" title={`${siteConfig.name} RSS Feed`} href="/rss.xml" />

    <!-- JSON-LD Structured Data -->
    <JsonLd schema={schemas} />

    <!-- Analytics (loads if PUBLIC_GA_MEASUREMENT_ID or PUBLIC_GTM_ID is set) -->
    <Analytics />

    <!-- Client-side routing for view transitions -->
    <ClientRouter />

    <!-- Theme script (runs before render to prevent flash) -->
    <script is:inline>
      (function () {
        const theme = localStorage.getItem('theme');
        const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;

        if (theme === 'dark' || (!theme && systemDark)) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
  </head>

  <body class="min-h-screen bg-background text-foreground antialiased">
    <!-- Skip to content link -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-primary focus:px-4 focus:py-2 focus:text-primary-foreground"
    >
      Skip to content
    </a>

    <slot name="header" />

    <main id="main-content" class="flex-1">
      <slot />
    </main>

    <Footer 
      slot="footer" 
      layout="columns"
      columns={4} 
      background="secondary" 
      showSocial={false} 
      showCopyright={false}
    >
      {/* COLUMN 1: Logo & Tagline (Injected via slots) */}
      <a href="/" slot="logo" class="block mb-2">
        <img src={lightLogo.src} alt="Brighton and Co" class="h-10 w-auto dark:hidden" />
        <img src={darkLogo.src} alt="Brighton and Co" class="h-10 w-auto hidden dark:block" />
      </a>
      <span slot="tagline" class="block leading-relaxed">
        Brighton and Co - showcasing personal projects, photography and other things.
      </span>

      {/* COLUMNS 2, 3 & 4 (Injected via the 'columns' slot to override default linkGroups) */}
      <Fragment slot="columns">
        
        {/* Column 2: Quick Links */}
        <div class="space-y-[var(--space-stack-md)]">
          <h3 class="font-semibold text-sm text-foreground">Quick Links</h3>
          <ul class="space-y-2">
            <li><a href="/about" class="text-sm text-foreground-muted hover:text-foreground transition-colors">About</a></li>
            <li><a href="/shop" class="text-sm text-foreground-muted hover:text-foreground transition-colors">Shop</a></li>
            <li><a href="/blog" class="text-sm text-foreground-muted hover:text-foreground transition-colors">Blog</a></li>
            <li><a href="/photography" class="text-sm text-foreground-muted hover:text-foreground transition-colors">Photography</a></li>
            <li><a href="/contact" class="text-sm text-foreground-muted hover:text-foreground transition-colors">Contact</a></li>
          </ul>
        </div>

        {/* Column 3: Social Links */}
        <div class="space-y-[var(--space-stack-md)]">
          <h3 class="font-semibold text-sm text-foreground">Connect</h3>
          <ul class="space-y-2">
            {/* FIXED: Replaced standard <a> tags with our custom ExternalLink components */}
            <li>
              <ExternalLink client:load disableHover={true} href="https://twitter.com/itsharryb_" className="group flex items-center gap-2 text-sm text-foreground-muted hover:text-foreground transition-colors">
                <Icon name="twitter" size="sm" class="group-hover:text-brand-500 transition-colors" /> Twitter
              </ExternalLink>
            </li>
            <li>
              <ExternalLink client:load disableHover={true} href="https://github.com/ItsHarryB" className="group flex items-center gap-2 text-sm text-foreground-muted hover:text-foreground transition-colors">
                <Icon name="github" size="sm" class="group-hover:text-brand-500 transition-colors" /> GitHub
              </ExternalLink>
            </li>
            <li>
              <ExternalLink client:load disableHover={true} href="https://www.linkedin.com/in/harry-brighton/" className="group flex items-center gap-2 text-sm text-foreground-muted hover:text-foreground transition-colors">
                <Icon name="linkedin" size="sm" class="group-hover:text-brand-500 transition-colors" /> LinkedIn
              </ExternalLink>
            </li>
            <li>
              <ExternalLink client:load disableHover={true} href="https://linktr.ee/brightonandco" className="group flex items-center gap-2 text-sm text-foreground-muted hover:text-foreground transition-colors">
                <Icon name="brand-linktree" size="sm" class="group-hover:text-brand-500 transition-colors" /> Linktree
              </ExternalLink>
            </li>
          </ul>
        </div>

        {/* Column 4: Site Info & Meta */}
        <div class="space-y-[var(--space-stack-md)]">
          <h3 class="font-semibold text-sm text-foreground">Site Info</h3>
          <div class="space-y-2 text-sm text-foreground-muted">
           <p>Version: <span class="font-mono bg-surface-secondary px-1.5 py-0.5 rounded-md border border-border">v{packageData.version}</span></p>
            <div class="pt-1 space-y-1">
              <p>&copy; {new Date().getFullYear()} Brighton and Co.</p>
              <p>All rights reserved.</p>
           </div>
            {/* ADDED: Terms and Conditions internal link */}
            <div class="pt-2 mt-2 border-t border-border/50">
              <a href="/terms-and-conditions" class="text-sm text-foreground-muted hover:text-foreground transition-colors block py-1">
                Terms & Conditions
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
        
      </Fragment>

      {/* OVERRIDE: Hide the bottom bar since we moved copyright to Column 4 */}
      <div slot="bottom" class="hidden"></div>
    </Footer>

    {/* ADDED transition:persist to keep the dialog alive across all page navigations */}
    <GlobalExternalLinkDialog client:idle transition:persist="global-external-link-dialog" />
    <ConsentBanner />
  </body>
</html>