---
import Icon from '@/components/ui/primitives/Icon/Icon.astro';

// We reuse the exact gradient style exclusively for the SHOP highlight
const gradientStyle = "background-image: linear-gradient(135deg, #ff0055, #ff2e43);";
---

<div id="text-carousel" tabindex="0" class="group relative w-full max-w-4xl mx-auto px-4 sm:px-6 text-center outline-none focus-visible:ring-2 focus-visible:ring-brand-500 rounded-3xl">
  
  {/* The Adaptive Glass Container */}
  <div class="carousel-container relative overflow-hidden rounded-3xl bg-background/25 dark:bg-background/40 backdrop-blur-xl border border-border shadow-2xl">
    
    {/* Navigation Arrows: Strictly hidden on mobile (<768px) to prevent text overlap, fades in on desktop hover */}
    <button id="prev-btn" aria-label="Previous slide" class="liquid-carousel-btn absolute left-4 top-0 bottom-0 my-auto w-12 h-12 hidden md:flex items-center justify-center opacity-0 group-hover:opacity-100 z-30 outline-none focus-visible:ring-2 focus-visible:ring-brand-500">
      <Icon name="chevron-left" class="w-6 h-6" />
    </button>
    <button id="next-btn" aria-label="Next slide" class="liquid-carousel-btn absolute right-4 top-0 bottom-0 my-auto w-12 h-12 hidden md:flex items-center justify-center opacity-0 group-hover:opacity-100 z-30 outline-none focus-visible:ring-2 focus-visible:ring-brand-500">
      <Icon name="chevron-right" class="w-6 h-6" />
    </button>

    {/* The Sliding Flex Track */}
    <div id="carousel-track" class="flex w-full touch-pan-y">
      
      {/* Slide 1: Welcome */}
      <div class="carousel-slide w-full shrink-0 flex flex-col items-center justify-center px-8 md:px-24 py-12 md:py-16">
        <h2 class="text-3xl md:text-5xl font-bold text-white mb-4 tracking-tight drop-shadow-sm">
          Welcome to <span class="text-brand-500">Brighton and Co</span>
        </h2>
        <p class="text-lg md:text-xl text-white/90 drop-shadow-sm max-w-2xl mb-8">
          A small website maintained as a hobby project, showcasing my personal interests in photography, design, and technology.
        </p>
        <a href="/about" class="liquid-carousel-btn inline-flex items-center justify-center gap-2 px-6 py-3 font-semibold pointer-events-auto outline-none focus-visible:ring-2 focus-visible:ring-brand-500">
          Learn More <Icon name="arrow-right" class="w-4 h-4" />
        </a>
      </div>

      {/* Slide 2: Shop */}
      <div class="carousel-slide w-full shrink-0 flex flex-col items-center justify-center px-8 md:px-24 py-12 md:py-16">
        <h2 class="text-3xl md:text-5xl font-bold text-white mb-4 tracking-tight drop-shadow-sm">
          <span class="text-transparent bg-clip-text" style={gradientStyle}>SHOP</span>: B&Co
        </h2>
        <p class="text-lg md:text-xl text-white/90 drop-shadow-sm max-w-2xl mb-8">
          Explore a small selection of pre-loved fashion and other items - direct from my Vinted and eBay stores.
        </p>
        <p class="text-lg md:text-xl text-white/90 drop-shadow-sm max-w-2xl mb-8">
          All items are in excellent condition, unless otherwise stated - all are packaged and shipped with care.
        </p>
        <a href="/shop" class="liquid-carousel-btn inline-flex items-center justify-center gap-2 px-6 py-3 font-semibold pointer-events-auto outline-none focus-visible:ring-2 focus-visible:ring-brand-500">
          Visit the Shop <Icon name="handbag" class="w-4 h-4" />
        </a>
      </div>

      {/* Slide 3: Photography */}
      <div class="carousel-slide w-full shrink-0 flex flex-col items-center justify-center px-8 md:px-24 py-12 md:py-16">
        <h2 class="text-3xl md:text-5xl font-bold text-white mb-4 tracking-tight drop-shadow-sm">
          My <span class="text-brand-500">Photography</span>
        </h2>
        <p class="text-lg md:text-xl text-white/90 drop-shadow-sm max-w-2xl mb-8">
          A dedicated gallery space showcasing my passion for photography, featuring high-resolution landscapes and other moments.
        </p>
        <a href="/photography" class="liquid-carousel-btn inline-flex items-center justify-center gap-2 px-6 py-3 font-semibold pointer-events-auto outline-none focus-visible:ring-2 focus-visible:ring-brand-500">
          View Gallery <Icon name="camera" class="w-4 h-4" />
        </a>
      </div>

    </div>

    {/* The Adaptive CSS Progress Bar */}
    <div class="absolute bottom-0 left-0 w-full h-1.5 bg-foreground/10 z-30">
      <div id="carousel-progress" class="h-full bg-foreground w-0"></div>
    </div>

  </div>
</div>

<style is:global>
  @keyframes progress-fill {
    0% { width: 0%; }
    100% { width: 100%; }
  }
  
  .animate-progress {
    animation: progress-fill 8s linear forwards;
  }
  
  .pause-progress {
    animation-play-state: paused !important;
  }

  /* 1-Time Peek Animation to show users the box is swipeable */
  @keyframes swipe-peek {
    0%, 100% { transform: translateX(-100%); }
    50% { transform: translateX(-104%); }
  }
  
  .animate-peek {
    animation: swipe-peek 1s cubic-bezier(0.25, 1, 0.5, 1) ease-in-out;
  }

  @property --glass-angle {
    syntax: "<angle>";
    inherits: false;
    initial-value: -75deg;
  }

  .liquid-carousel-btn {
    isolation: isolate; 
    color: var(--color-foreground); 
    border-radius: 9999px; 
    
    transform: translateY(0) scale(1);
    transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1), box-shadow 0.3s ease-out, opacity 0.3s ease;
    will-change: transform, box-shadow;
    
    background: color-mix(in oklch, var(--color-background) 60%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--color-border);
    box-shadow: 
      inset 0 0.125rem 0.125rem rgba(0, 0, 0, 0.05),
      inset 0 -0.125rem 0.125rem rgba(255, 255, 255, 0.5),
      0 0.25rem 0.125rem -0.125rem rgba(0, 0, 0, 0.2),
      0 0 0.1rem 0.25rem inset rgba(255, 255, 255, 0.2);
  }

  .liquid-carousel-btn:hover {
    transform: translateY(-2px) scale(1.02);
    box-shadow: 
      inset 0 0.125rem 0.125rem rgba(0, 0, 0, 0.05),
      inset 0 -0.125rem 0.125rem rgba(255, 255, 255, 0.6),
      0 0.5rem 0.5rem -0.25rem rgba(0, 0, 0, 0.3),
      0 0 0.1rem 0.25rem inset rgba(255, 255, 255, 0.2);
  }
  
  .liquid-carousel-btn:active {
    transform: translateY(1px) scale(0.96);
    box-shadow: 
      inset 0 0.125rem 0.125rem rgba(0, 0, 0, 0.05),
      inset 0 -0.125rem 0.125rem rgba(255, 255, 255, 0.4),
      0 0.125rem 0.125rem -0.125rem rgba(0, 0, 0, 0.1),
      0 0 0.1rem 0.25rem inset rgba(255, 255, 255, 0.2);
  }

  .liquid-carousel-btn::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px; 
    background: conic-gradient(from var(--glass-angle) at 50% 50%, rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0) 5% 40%, rgba(0, 0, 0, 0.5) 50%, rgba(0, 0, 0, 0) 60% 95%, rgba(0, 0, 0, 0.5)), linear-gradient(180deg, rgba(255, 255, 255, 0.5), rgba(255, 255, 255, 0.5));
    -webkit-mask-composite: xor;
    mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    mask-composite: exclude;
    pointer-events: none;
    box-shadow: inset 0 0 0 0.5px rgba(255, 255, 255, 0.5);
  }

  .liquid-carousel-btn::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.2), rgba(0, 0, 0, 0.1));
    filter: blur(8px);
    z-index: -1;
    transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .liquid-carousel-btn:hover::before {
    transform: translateY(4px);
  }
</style>

<script>
  function initCarousel() {
    const carousel = document.getElementById('text-carousel') as HTMLElement;
    const track = document.getElementById('carousel-track') as HTMLElement;
    
    if (!carousel || !track) return;
    
    if (track.dataset.initialized) return;
    track.dataset.initialized = "true";

    const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
    const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
    const progress = document.getElementById('carousel-progress') as HTMLElement;
    
    // Infinite Loop Setup
    const originalSlides = Array.from(track.children) as HTMLElement[];
    const firstClone = originalSlides[0].cloneNode(true) as HTMLElement;
    const lastClone = originalSlides[originalSlides.length - 1].cloneNode(true) as HTMLElement;
    
    track.appendChild(firstClone);
    track.insertBefore(lastClone, originalSlides[0]);

    let currentIndex = 1;
    let isTransitioning = false;
    let isPaused = false;
    let autoPlayTimer: number;
    const totalSlides = originalSlides.length;
    const SLIDE_DURATION = 8000; // 8 Seconds per slide

    // Position track instantly
    track.style.transition = 'none';
    track.style.transform = `translateX(-${currentIndex * 100}%)`;

    function dispatchSlideChange() {
      const realIndex = (currentIndex - 1 + totalSlides) % totalSlides;
      document.dispatchEvent(new CustomEvent('slideChanged', { detail: { index: realIndex } }));
    }

    // Bulletproof Native JS Timer for Auto-Scrolling
    function startAutoPlay() {
      stopAutoPlay();
      resetProgress();
      autoPlayTimer = window.setInterval(() => {
        if (!isPaused) nextSlide();
      }, SLIDE_DURATION);
    }

    function stopAutoPlay() {
      if (autoPlayTimer) clearInterval(autoPlayTimer);
    }

    function updateSlide(smooth = true) {
      if (!track) return;
      
      if (smooth) {
        track.style.transition = 'transform 700ms cubic-bezier(0.25, 1, 0.5, 1)';
      } else {
        track.style.transition = 'none';
      }
      track.style.transform = `translateX(-${currentIndex * 100}%)`;
      dispatchSlideChange();
      startAutoPlay();
    }

    function resetProgress() {
      if (progress) {
        progress.classList.remove('animate-progress');
        void progress.offsetWidth; 
        progress.classList.add('animate-progress');
        progress.classList.toggle('pause-progress', isPaused);
      }
    }

    track.addEventListener('transitionend', () => {
      isTransitioning = false;
      if (currentIndex === totalSlides + 1) {
        currentIndex = 1;
        updateSlide(false);
      } else if (currentIndex === 0) {
        currentIndex = totalSlides;
        updateSlide(false);
      }
    });

    function nextSlide() {
      if (isTransitioning) return;
      isTransitioning = true;
      currentIndex++;
      updateSlide(true);
    }

    function prevSlide() {
      if (isTransitioning) return;
      isTransitioning = true;
      currentIndex--;
      updateSlide(true);
    }

    prevBtn?.addEventListener('click', prevSlide);
    nextBtn?.addEventListener('click', nextSlide);

    // Pause on Interaction
    const pauseCarousel = () => {
      isPaused = true;
      stopAutoPlay();
      progress?.classList.add('pause-progress');
    };
    
    const resumeCarousel = () => {
      isPaused = false;
      startAutoPlay();
      progress?.classList.remove('pause-progress');
    };

    carousel.addEventListener('mouseenter', pauseCarousel);
    carousel.addEventListener('mouseleave', resumeCarousel);
    carousel.addEventListener('touchstart', pauseCarousel, { passive: true });
    carousel.addEventListener('touchend', resumeCarousel, { passive: true });

    carousel.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') { e.preventDefault(); prevSlide(); }
      if (e.key === 'ArrowRight') { e.preventDefault(); nextSlide(); }
    });

    let isScrolling = false;
    track.addEventListener('wheel', (e) => {
      if (Math.abs(e.deltaX) > 30 && !isScrolling) {
        isScrolling = true;
        if (e.deltaX > 0) nextSlide();
        else prevSlide();
        setTimeout(() => isScrolling = false, 500); 
      }
    }, { passive: true });

    let touchStartX = 0;
    track.addEventListener('touchstart', (e) => {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });

    track.addEventListener('touchend', (e) => {
      const touchEndX = e.changedTouches[0].screenX;
      const diff = touchStartX - touchEndX;
      if (diff > 50) nextSlide();
      else if (diff < -50) prevSlide();
    }, { passive: true });

    // 1-Time "Swipe Hint" Peek Animation (Triggers 1.5s after load)
    setTimeout(() => {
      if (!isPaused && currentIndex === 1) {
        track.classList.add('animate-peek');
        track.addEventListener('animationend', () => {
          track.classList.remove('animate-peek');
        }, { once: true });
      }
    }, 1500);

    // Start everything up!
    setTimeout(dispatchSlideChange, 50);
    startAutoPlay();
  }

  initCarousel();
  document.addEventListener('astro:page-load', initCarousel);
</script>