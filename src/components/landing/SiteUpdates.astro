---

{/* COLLAPSIBLE UPDATES WIDGET */}
{/* FIXED: Removed max-w-[500px], changed to w-full so it fills the grid column */}
<div 
  id="updates-widget" 
  class="relative w-full rounded-3xl border border-border bg-surface-secondary/50 shadow-sm backdrop-blur-sm overflow-hidden transition-all duration-300 h-[76px] md:h-[450px]"
>
  {/* Mobile Toggle Button (+ / -) */}
  <button 
    id="updates-toggle" 
    class="absolute right-5 top-5 z-20 flex h-8 w-8 items-center justify-center rounded-md border border-border bg-background shadow-sm text-foreground transition-colors hover:bg-surface-secondary md:hidden"
    aria-label="Toggle site updates"
  >
    <span id="updates-plus" class="flex items-center justify-center"><Icon name="plus" class="h-4 w-4" /></span>
    <span id="updates-minus" class="hidden items-center justify-center"><Icon name="minus" class="h-4 w-4" /></span>
  </button>

  {/* The Scroll Area Wrapper */}
  {/* FIXED: Added [&>[data-radix-scroll-area-viewport]]:!w-full to force Radix to stretch text across the full box */}
  <div id="updates-scroll-wrapper" class="h-full w-full pointer-events-none md:pointer-events-auto [&>[data-radix-scroll-area-viewport]]:!w-full [&>[data-radix-scroll-area-viewport]]:!block">
    <ScrollArea client:load type="auto" className="h-full w-full">
      <div class="p-6 md:p-8">
        <div class="mb-6 flex items-center gap-2 border-b border-border/50 pb-4">
          <Icon name="bell" size="sm" class="text-brand-500" />
          <h2 class="text-lg font-bold text-foreground">Site Updates:</h2>
        </div>
        
        <div class="flex flex-col gap-1">
          {siteUpdates.map((update, index) => (
            <>
              <div class="group flex flex-col gap-2 py-3">
                <div class="flex flex-wrap items-center justify-between gap-2">
                  <span class="inline-flex items-center rounded-full bg-brand-500/10 px-2.5 py-0.5 text-xs font-semibold text-brand-500 border border-brand-500/20">
                    {update.version}
                  </span>
                  <span class="text-xs font-medium text-foreground-muted/80">
                    {update.date}
                  </span>
                </div>
                <div>
                  <h3 class="text-base font-semibold text-foreground group-hover:text-brand-500 transition-colors">
                    {update.title}
                  </h3>
                  <p class="mt-1 text-sm text-foreground-muted leading-relaxed">
                    {update.description}
                  </p>
                </div>
              </div>
              {index !== siteUpdates.length - 1 && (
                <Separator class="my-1 opacity-50" />
              )}
            </>
          ))}
        </div>
      </div>
    </ScrollArea>
  </div>
</div>

<script>
  function initSiteUpdates() {
    const widget = document.getElementById('updates-widget');
    const toggleBtn = document.getElementById('updates-toggle');
    const plusIcon = document.getElementById('updates-plus');
    const minusIcon = document.getElementById('updates-minus');
    const scrollWrapper = document.getElementById('updates-scroll-wrapper');

    if (toggleBtn && widget && scrollWrapper && !toggleBtn.dataset.initialized) {
      toggleBtn.dataset.initialized = 'true';
      
      toggleBtn.addEventListener('click', () => {
        if (widget.classList.contains('h-[450px]')) {
          const viewport = scrollWrapper.querySelector('[data-radix-scroll-area-viewport]');
          if (viewport) {
            viewport.scrollTop = 0;
          }
        }

        widget.classList.toggle('h-[76px]');
        widget.classList.toggle('h-[450px]');

        plusIcon?.classList.toggle('hidden');
        minusIcon?.classList.toggle('hidden');

        scrollWrapper.classList.toggle('pointer-events-none');
      });
    }
  }

  initSiteUpdates();
  document.addEventListener('astro:page-load', initSiteUpdates);
</script>